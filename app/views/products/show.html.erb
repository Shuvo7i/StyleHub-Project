<div class="min-h-screen bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    
    <%= link_to "← Back to Products", root_path, class: "inline-block mb-6 text-blue-600 hover:text-blue-800 font-medium" %>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2">
        
        <div class="w-full bg-gray-100 flex items-center justify-center p-6 min-h-[300px]">
          <% if @product.image.attached? %>
            <%= image_tag @product.image, class: "max-h-[400px] max-w-full object-contain mx-auto min-h-[400px]" %>
          <% else %>
            <span class="text-gray-400 text-sm">No Image</span>
          <% end %>
        </div>

        <div class="p-8">
          <p class="text-sm text-blue-600 font-medium mb-3">
            <%= @product.category.name %>
          </p>

          <h1 class="text-3xl font-bold text-gray-900 mb-4">
            <%= @product.name %>
          </h1>

          <p class="text-3xl font-bold text-green-600 mb-6">
            <%= number_to_currency(@product.price) %>
          </p>

          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-lg font-semibold text-gray-800 mb-2">Description</h2>
            <p class="text-gray-600 leading-7">
              <%= @product.description %>
            </p>
            
          </div>
                        <div>
                        </br> 
                        </div>
          <%= button_to "Add to Cart", add_to_cart_path(@product), method: :post, class: "inline-block bg-green-600 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-green-700 transition border-0" %>
        </div>
        
      </div>
    </div>
  </div>
</div>