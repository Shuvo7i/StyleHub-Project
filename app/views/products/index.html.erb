<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-10">
      <h1 class="text-4xl font-bold text-gray-900">All Products</h1>
      <p class="mt-2 text-gray-600">Browse our latest items.</p>
    </div>

    <div class="mb-6 flex flex-wrap items-center gap-3">
      <%= link_to "Browse by Category", categories_path, class: "inline-block bg-gray-900 text-white px-5 py-3 rounded-lg hover:bg-gray-800 transition" %>

      <%= link_to "View Cart", cart_path, class: "ml-auto inline-block bg-green-600 text-white px-5 py-3 rounded-lg hover:bg-green-700 transition" %>
    </div>

    <%= render "filters" %>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <%= render @products %>
    </div>

    <%= render "pagination" %>
  </div>
</div>