  [&_.pagination]:p-2
  [&_.pagination]:shadow-sm
  [&_.pagination_a]:inline-flex
  [&_.pagination_a]:h-10
  [&_.pagination_a]:min-w-[40px]
  [&_.pagination_a]:items-center
  [&_.pagination_a]:justify-center
  [&_.pagination_a]:rounded-xl
  [&_.pagination_a]:px-4
  [&_.pagination_a]:text-sm
  [&_.pagination_a]:font-medium
  [&_.pagination_a]:text-gray-700
  [&_.pagination_a]:transition
  [&_.pagination_a:hover]:bg-gray-100
  [&_.pagination_a:hover]:text-blue-600
  [&_.pagination_.current]:inline-flex
