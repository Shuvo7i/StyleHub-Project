

<div class="min-h-screen bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-4xl font-bold text-gray-900">Shopping Cart</h1>
        <p class="mt-2 text-gray-600">Items saved in your session.</p>
      </div>

      <%= link_to "Continue Shopping", root_path, class: "inline-block bg-blue-600 text-white px-5 py-3 rounded-lg hover:bg-blue-700 transition" %>
    </div>
    <% if user_signed_in? %>
  <span class="text-gray-700">Hi, <%= current_user.username.presence || current_user.email %></span>
  <%= link_to "Edit Account", edit_user_registration_path, class: "inline-block bg-gray-900 text-white px-4 py-2 rounded-lg hover:bg-gray-800 transition" %>
  <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "inline-block bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition border-0" %>
<% else %>
  <%= link_to "Sign Up", new_user_registration_path, class: "inline-block bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition" %>
  <%= link_to "Login", new_user_session_path, class: "inline-block bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition" %>
<% end %>

    <% if @cart_items.any? %>
      <div class="space-y-4">
        <% @cart_items.each do |item| %>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
              <div>
                <h2 class="text-xl font-semibold text-gray-900">
                  <%= item[:product].name %>
                </h2>
                <p class="text-sm text-gray-500 mt-1">
                  Category: <%= item[:product].category.name %>
                </p>
                <p class="text-sm text-green-600 font-semibold mt-2">
                  <%= number_to_currency(item[:product].price) %> each
                </p>
              </div>

              <div class="flex flex-col sm:flex-row sm:items-center gap-3">
                <%= form_with url: update_cart_path(item[:product]), method: :patch, local: true, class: "flex items-center gap-2" do %>
                  <%= number_field_tag :quantity, item[:quantity], min: 1, class: "w-20 rounded-lg border border-gray-300 px-3 py-2" %>
                  <%= submit_tag "Update", class: "bg-yellow-500 text-white px-4 py-2 rounded-lg hover:bg-yellow-600 transition cursor-pointer" %>
                <% end %>

                <%= button_to "Remove", remove_from_cart_path(item[:product]), method: :delete, class: "bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition border-0" %>
              </div>
            </div>

            <div class="mt-4 border-t border-gray-200 pt-4 flex justify-between items-center">
              <span class="text-gray-600">Subtotal</span>
              <span class="text-lg font-bold text-green-600">
                <%= number_to_currency(item[:subtotal]) %>
              </span>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-8 bg-white rounded-2xl shadow-sm border border-gray-200 p-6 flex items-center justify-between">
        <h3 class="text-2xl font-bold text-gray-900">Total</h3>
        <p class="text-2xl font-bold text-green-600">
          <%= number_to_currency(@cart_total) %>
        </p>
        <div class="mt-8 bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-2xl font-bold text-gray-900">Total</h3>
    <p class="text-2xl font-bold text-green-600">
      <%= number_to_currency(@cart_total) %>
    </p>
  </div>

  <%= link_to "Proceed to Checkout", checkout_path, class: "inline-block bg-green-600 text-white px-5 py-3 rounded-lg hover:bg-green-700 transition" %>
</div>
      </div>
    <% else %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-10 text-center">
        <p class="text-lg text-gray-600">Your cart is empty.</p>
      </div>
    <% end %>
  </div>
</div>