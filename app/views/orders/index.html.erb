<div class="min-h-screen bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-4xl font-bold text-gray-900">My Orders</h1>
        <p class="mt-2 text-gray-600">Review your past orders, products, taxes, and totals.</p>
      </div>

      <%= link_to "Back to Products", root_path, class: "inline-block bg-blue-600 text-white px-5 py-3 rounded-lg hover:bg-blue-700 transition" %>
    </div>

    <% if @orders.any? %>
      <div class="space-y-6">
        <% @orders.each do |order| %>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-4">
              <div>
                <h2 class="text-2xl font-semibold text-gray-900">Order #<%= order.id %></h2>
                <p class="text-sm text-gray-500 mt-1">
                  Placed on <%= order.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                </p>
              </div>

              <%= link_to "View Full Invoice", order_path(order), class: "inline-block bg-gray-900 text-white px-4 py-2 rounded-lg hover:bg-gray-800 transition" %>
            </div>

            <div class="overflow-x-auto">
              <table class="min-w-full border border-gray-200 rounded-xl overflow-hidden">
                <thead class="bg-gray-100">
                  <tr>
                    <th class="text-left px-4 py-3 text-gray-700">Product</th>
                    <th class="text-left px-4 py-3 text-gray-700">Qty</th>
                    <th class="text-left px-4 py-3 text-gray-700">Unit Price</th>
                    <th class="text-left px-4 py-3 text-gray-700">Subtotal</th>
                  </tr>
                </thead>
                <tbody>
                  <% order.order_items.each do |item| %>
                    <tr class="border-t border-gray-200">
                      <td class="px-4 py-3"><%= item.product.name %></td>
                      <td class="px-4 py-3"><%= item.quantity %></td>
                      <td class="px-4 py-3"><%= number_to_currency(item.unit_price) %></td>
                      <td class="px-4 py-3"><%= number_to_currency(item.subtotal) %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <div class="mt-6 max-w-md ml-auto space-y-2">
              <div class="flex justify-between">
                <span class="text-gray-700">Subtotal</span>
                <span class="font-semibold"><%= number_to_currency(order.subtotal) %></span>
              </div>

              <% if order.gst_amount.to_f > 0 %>
                <div class="flex justify-between">
                  <span class="text-gray-700">GST</span>
                  <span class="font-semibold"><%= number_to_currency(order.gst_amount) %></span>
                </div>
              <% end %>

              <% if order.pst_amount.to_f > 0 %>
                <div class="flex justify-between">
                  <span class="text-gray-700"><%= order.provincial_tax_label %></span>
                  <span class="font-semibold"><%= number_to_currency(order.pst_amount) %></span>
                </div>
              <% end %>

              <% if order.hst_amount.to_f > 0 %>
                <div class="flex justify-between">
                  <span class="text-gray-700">HST</span>
                  <span class="font-semibold"><%= number_to_currency(order.hst_amount) %></span>
                </div>
              <% end %>

              <div class="border-t border-gray-200 pt-2 flex justify-between text-lg">
                <span class="font-bold text-gray-900">Grand Total</span>
                <span class="font-bold text-green-600"><%= number_to_currency(order.total) %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-10 text-center">
        <p class="text-lg text-gray-600">You have no past orders yet.</p>
      </div>
    <% end %>
  </div>
</div>